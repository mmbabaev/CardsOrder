# ==============================================
# Конфигурация Telegram Bot для CardsOrder
# ==============================================

# Telegram Bot Token (получить у @BotFather)
# 1. Найдите @BotFather в Telegram
# 2. Отправьте команду /newbot
# 3. Следуйте инструкциям и скопируйте полученный токен
# Формат: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=your_bot_token_here

# Временная директория для файлов
# Путь, куда будут сохраняться загруженные HTML файлы и сгенерированные Excel
# Убедитесь, что директория существует или бот имеет права на её создание
TEMP_DIR=/tmp/cards-order-bot

# Максимальный размер файла (в байтах)
# По умолчанию: 25MB (26214400 байт)
# Telegram Bot API имеет лимит 50MB, но рекомендуется использовать меньше
MAX_FILE_SIZE=26214400

# Уровень логирования
# Возможные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG - максимально подробные логи (для разработки)
# INFO - стандартные логи (рекомендуется для продакшена)
# WARNING - только предупреждения и ошибки
# ERROR - только ошибки
LOG_LEVEL=INFO

# Директория для логов (опционально)
# Если не указана, логи будут выводиться только в консоль
# LOG_DIR=/var/log/cards-order-bot

# Максимальное количество файлов в обработке одновременно (опционально)
# MAX_CONCURRENT_JOBS=5

# Таймаут обработки файла в секундах (опционально)
# PROCESSING_TIMEOUT=300