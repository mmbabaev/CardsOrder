.cart-recommended-product { padding: 2em 1em 0px; }

.cart-recommended-product img { max-width: 100%; }

.cart-sidebar h4 { margin-top: 0px; }

.lineitemQuantity .cart-tag { min-width: 70px; }

.cart-main { margin-top: 15px; }

.cart-main h1 { margin-top: 0px; padding-top: 0px; }

